# Copy this file to .env and fill in your Bedrock API key.
# A Bedrock "API key" is a bearer token; boto3 reads it from this env var.
# Temporary keys are scoped to one region and expire (often ~12h) — mind both.
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_api_key_here

AWS_REGION=us-east-1

# Chat model via the Bedrock Converse API (works with any model, not just gpt-oss).
# Default = best non-Anthropic model. Other verified options you can drop in here:
#   deepseek.v3.2
#   mistral.mistral-large-3-675b-instruct
#   zai.glm-5
#   qwen.qwen3-next-80b-a3b
#   openai.gpt-oss-120b-1:0
#   us.amazon.nova-pro-v1:0
#   us.amazon.nova-2-lite-v1:0   (fast / cheap)
CHAT_MODEL_ID=moonshotai.kimi-k2.5

# Embedding model (Bedrock, fast & server-side). Alt: cohere.embed-english-v3
EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
